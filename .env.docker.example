# Copy to .env.docker and fill in — read by docker-compose into the backend container.
# Do NOT set PYTHON_BIN or DATA_DIR here; the container pins those itself.

JWT_SECRET=change-me-to-a-long-random-string

# Default provider for new users: "openai" or "local"
DEFAULT_PROVIDER=openai

# --- OpenAI provider ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Local (llama) provider: external Ollama / llama.cpp on the host ---
LOCAL_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_API_KEY=ollama
LOCAL_CHAT_MODEL=qwen2.5:7b-instruct
LOCAL_EMBED_MODEL=nomic-embed-text

# Optional: where the SQLite DB / indexes / uploads live on the HOST.
# (Read at compose time for the volume mount; default ./data)
# DATA_HOST_DIR=./data
