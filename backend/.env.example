# Server
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# Path to the Python interpreter used to run scripts in ./python
# On Windows this might be "py" or an absolute path to a venv python.
PYTHON_BIN=python

# --- OpenAI provider ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Local (llama) provider: any OpenAI-compatible server (Ollama, llama.cpp) ---
# Ollama default: http://localhost:11434/v1
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama
LOCAL_CHAT_MODEL=llama3.1
LOCAL_EMBED_MODEL=nomic-embed-text

# Default provider for new users: "openai" or "local"
DEFAULT_PROVIDER=openai

# --- Abuse / cost controls ---
# Max auth (login/signup) requests per IP per window.
AUTH_RATE_MAX=20
AUTH_RATE_WINDOW_MS=900000
# Max LLM + embedding tokens per user per hour (0 disables the cap).
TOKEN_LIMIT_PER_HOUR=100000
