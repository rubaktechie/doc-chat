{
  "name": "doc-chat-backend",
  "version": "1.0.0",
  "description": "Chat with Docs — Node/Express backend",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:clear": "node scripts/clear-db.js docs",
